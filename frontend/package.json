{
  "name": "@pitwall/frontend",
  "version": "0.1.0",
  "description": "PitWall Frontend - React Native mobile and web application",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "expo start",
    "web": "expo start --web",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "build": "tsc --noEmit && expo build:web",
    "lint": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\""
  },
  "dependencies": {
    "react": "18.2.0",
    "react-native": "0.72.0",
    "react-native-web": "0.19.0",
    "expo": "49.0.0",
    "expo-constants": "14.2.0",
    "expo-status-bar": "1.6.0",
    "@react-navigation/native": "6.0.8",
    "@react-navigation/bottom-tabs": "6.3.4",
    "@react-navigation/native-stack": "6.5.2",
    "react-native-screens": "3.20.0",
    "react-native-safe-area-context": "4.5.0",
    "@reduxjs/toolkit": "1.9.5",
    "react-redux": "8.1.1",
    "redux": "4.2.1",
    "zustand": "4.3.8",
    "axios": "1.4.0"
  },
  "devDependencies": {
    "@types/react": "18.2.14",
    "@types/react-native": "0.72.2",
    "@types/node": "20.3.1",
    "@typescript-eslint/eslint-plugin": "5.59.11",
    "@typescript-eslint/parser": "5.59.11",
    "eslint": "8.44.0",
    "jest": "29.5.0",
    "typescript": "5.0.4",
    "prettier": "3.0.0"
  }
}
